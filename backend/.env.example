# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (stores products, categories, pages, website config, and app-specific
# user profiles — role/wishlist/addresses. Firebase handles authentication itself.)
MONGO_URI=mongodb://127.0.0.1:27017/store_builder

# Firebase (Authentication). Only the project ID is needed for verifying
# requests — ID tokens are checked against Google's public keys, no service
# account required. FIREBASE_API_KEY (the public web API key, safe to expose)
# is only used by the optional `npm run seed` script to create a bootstrap
# admin account directly via the Firebase Auth REST API.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key
