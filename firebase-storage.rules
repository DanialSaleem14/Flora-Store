rules_version = '2';

// Paste this into Firebase Console -> Storage -> Rules, then click Publish.
//
// Why an email allowlist instead of a role check: our backend keeps the
// admin/customer role in MongoDB, not in Firebase itself, and reading that
// from a Storage rule would require Firebase custom claims (which need a
// service account — deliberately avoided so no extra secret is needed to
// run this project). For a small store with one or a few admins, listing
// their emails here is the simplest secure option. If you add another admin
// later, add their email to ADMIN_EMAILS below too. If this ever needs to
// scale to many admins, switch to custom claims + the Admin SDK instead.

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Anyone can view uploaded images (product photos, logos, banners) —
      // this is a public storefront.
      allow read: if true;

      // Only allowlisted admin accounts can upload or delete.
      allow write: if request.auth != null &&
        request.auth.token.email in [
          'admin@example.com',
          'flora.bym.pk@gmail.com'
        ] &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
